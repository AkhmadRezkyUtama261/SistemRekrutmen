# ═══════════════════════════════════════════════════════════════
# RecruitPro Enterprise — Root .htaccess
# @Author:      BE-06
# @Date:        2026-05-24
# @Description: Security headers, directory listing, file access control.
# ═══════════════════════════════════════════════════════════════

# Disable directory listing
Options -Indexes

# Follow symbolic links
Options +FollowSymLinks

# ── Deny access to sensitive files ──
<FilesMatch "\.(sql|md|json|env|yml|yaml|log|bak|sh|git)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block access to hidden files (.git, .env, etc.) ──
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block access to config directory ──
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to config directory
    RewriteRule ^config/ - [F,L]

    # Block direct access to includes directory
    RewriteRule ^includes/ - [F,L]

    # Block direct access to sql directory
    RewriteRule ^sql/ - [F,L]

    # Block direct access to docs directory
    RewriteRule ^docs/ - [F,L]
</IfModule>

# ── Security Headers ──
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Prevent PHP execution in uploads ──
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.php$ - [F,L]
</IfModule>

# ── Set default charset ──
AddDefaultCharset UTF-8

# ── PHP settings (if allowed) ──
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag log_errors on
    php_value upload_max_filesize 2M
    php_value post_max_size 3M
</IfModule>
